---
/**
 * Header.astro – Cabeçalho e navegação (tema 8links-test2)
 * Lê menu e logo do singleton 'menu' do CNX (compatível com temas F8).
 */
import { readSingleton } from '../../../utils/singleton-utils';

const { activeThemeId } = Astro.props;
const menuData = await readSingleton('menu', activeThemeId);
const contactData = await readSingleton('contact', activeThemeId);
const logoText = menuData?.logoText || '8links';
const headerPhone = (contactData?.phone as string) || '';
const navItems = (menuData?.items || []).map((i: { label?: string; url?: string; href?: string }) => ({
  label: i.label,
  href: i.url || i.href || '#',
  children: (i as any).children,
}));
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#0f0f0f]/95 backdrop-blur border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center shrink-0" aria-label="8links - Início">
        <span class="text-xl font-bold text-[#D9F45F]">{logoText}</span>
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Navegação principal">
        {navItems.map((item) => (
          (item.href && !item.children) ? (
            <a
              href={item.href}
              class="text-sm font-medium text-white/90 hover:text-[#D9F45F] transition-colors py-2 min-h-[44px] min-w-[44px] flex items-center"
            >
              {item.label}
            </a>
          ) : item.children && item.children.length > 0 ? (
            <div class="relative group">
              <button
                type="button"
                class="text-sm font-medium text-white/90 hover:text-[#D9F45F] transition-colors py-2 flex items-center gap-1 min-h-[44px]"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all bg-[#131212] rounded-lg shadow-xl min-w-[200px]">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-white/90 hover:bg-[#D9F45F]/10 hover:text-[#D9F45F] first:rounded-t-lg last:rounded-b-lg"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : null
        ))}
      </nav>

      <div class="flex items-center gap-4">
        {headerPhone && (
          <a href={`tel:${headerPhone.replace(/\s/g, '')}`} class="hidden md:flex items-center gap-2 text-sm text-white/90 hover:text-[#D9F45F] min-h-[44px]">
            <span aria-hidden="true">📞</span>
            {headerPhone}
          </a>
        )}

        <button
          type="button"
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md text-white/90 hover:bg-white/10 min-h-[44px] min-w-[44px] flex items-center justify-center"
          aria-label="Abrir menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden fixed inset-0 top-16 z-40 bg-[#0f0f0f] overflow-y-auto">
    <nav class="p-6 space-y-1">
      {navItems.map((item) => (
        (item.href && !item.children) ? (
          <a href={item.href} class="mobile-nav-link block py-3 px-4 text-lg text-white/90 hover:bg-white/5 hover:text-[#D9F45F] rounded-lg min-h-[44px] flex items-center">
            {item.label}
          </a>
        ) : item.children && item.children.length > 0 ? (
          <div class="space-y-1">
            <p class="py-3 px-4 text-lg font-medium text-white/70">{item.label}</p>
            {item.children.map((child: { href?: string; label?: string }) => (
              <a href={child.href || '#'} class="mobile-nav-link block py-3 px-8 text-base text-white/80 hover:bg-white/5 hover:text-[#D9F45F] rounded-lg min-h-[44px] flex items-center">
                {child.label}
              </a>
            ))}
          </div>
        ) : null
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    if (isHidden) {
      menu?.classList.remove('hidden');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>
