---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  publishDate: string;
  modifiedDate?: string;
  slug: string;
  image?: string;
  breadcrumbs: Array<{ label: string; href: string }>;
  toc?: Array<{ id: string; label: string; level?: 2 | 3 }>;
  affiliate?: boolean;
  readingTime?: number;
}

const {
  title,
  description,
  publishDate,
  modifiedDate,
  slug,
  image = "https://bicicletasergometricas.com/og-default.jpg",
  breadcrumbs,
  toc = [],
  affiliate = true,
  readingTime,
} = Astro.props;

const siteUrl = "https://bicicletasergometricas.com";
const canonicalUrl = `/${slug}`;
const datePublished = new Date(publishDate).toISOString();
const dateModified = modifiedDate ? new Date(modifiedDate).toISOString() : datePublished;

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  image,
  datePublished,
  dateModified,
  author: { "@type": "Organization", name: "Bicicletas Ergométricas", url: siteUrl },
  publisher: { "@type": "Organization", name: "Bicicletas Ergométricas", logo: { "@type": "ImageObject", url: `${siteUrl}/favicon.svg` } },
  mainEntityOfPage: { "@type": "WebPage", "@id": `${siteUrl}${canonicalUrl}` },
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteUrl },
    ...breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: crumb.label,
      item: `${siteUrl}${crumb.href}`,
    })),
  ],
};
---

<Layout title={title} description={description} canonical={canonicalUrl}>

  <!-- Schema extras no <head> via slot -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaArticle)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaBreadcrumb)} />

  <!-- Breadcrumb -->
  <nav aria-label="Localização" class="border-b border-gray-100 bg-gray-50 px-4 py-2 text-sm text-gray-500">
    <ol class="mx-auto flex max-w-6xl flex-wrap items-center gap-1">
      <li><a href="/" class="hover:text-rose-500">Início</a></li>
      {breadcrumbs.map((crumb, i) => (
        <>
          <li aria-hidden="true">/</li>
          <li>
            {i < breadcrumbs.length - 1
              ? <a href={crumb.href} class="hover:text-rose-500">{crumb.label}</a>
              : <span class="text-gray-800 font-medium" aria-current="page">{crumb.label}</span>
            }
          </li>
        </>
      ))}
    </ol>
  </nav>

  <!-- Layout artigo: conteúdo + sidebar TOC -->
  <div class="mx-auto max-w-6xl px-4 py-8 lg:flex lg:gap-10">

    <main class="min-w-0 flex-1">

      <header class="mb-8">
        <h1 class="mb-3 text-3xl font-extrabold leading-tight text-gray-900 lg:text-4xl">{title}</h1>
        <p class="mb-4 text-lg text-gray-600 leading-relaxed">{description}</p>
        <div class="flex flex-wrap gap-4 text-sm text-gray-500">
          <time datetime={datePublished}>
            Publicado em {new Date(publishDate).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })}
          </time>
          {modifiedDate && modifiedDate !== publishDate && (
            <time datetime={dateModified}>
              · Atualizado em {new Date(modifiedDate).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })}
            </time>
          )}
          {readingTime && <span>· {readingTime} min de leitura</span>}
        </div>
      </header>

      {affiliate && (
        <aside role="note" class="mb-8 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
          <strong>Transparência:</strong> Este site contém links de afiliado. Se você comprar por eles, recebemos uma comissão sem custo extra para você. Nossa curadoria é independente. <a href="/sobre" class="underline hover:text-amber-900">Saiba mais.</a>
        </aside>
      )}

      <article class="prose prose-rose max-w-none prose-headings:scroll-mt-24 prose-a:text-rose-500 prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg">
        <slot />
      </article>

      <footer class="mt-12 border-t border-gray-200 pt-6 text-sm text-gray-400">
        <p>Última atualização: <time datetime={dateModified}>{new Date(dateModified).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })}</time></p>
        <p class="mt-1">Informações baseadas em fichas técnicas dos fabricantes e avaliações públicas de usuários.</p>
      </footer>

    </main>

    {toc.length > 0 && (
      <aside class="hidden lg:block lg:w-64 lg:shrink-0">
        <div class="sticky top-24">
          <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Neste artigo</p>
          <ol class="space-y-1 text-sm">
            {toc.map((item) => (
              <li class={item.level === 3 ? "pl-3" : ""}>
                <a href={`#${item.id}`} class="block rounded px-2 py-1 text-gray-600 transition-colors hover:bg-rose-50 hover:text-rose-500">
                  {item.label}
                </a>
              </li>
            ))}
          </ol>
        </div>
      </aside>
    )}

  </div>

</Layout>