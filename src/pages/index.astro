---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import { fetchBikeImage } from '../lib/pexels.js';

const heroImage = {
  url: 'https://images.pexels.com/photos/775025/pexels-photo-775025.jpeg',
  alt: 'Mulher pedalando em bicicleta ergométrica',
  photographer: 'Pixabay',
  photographerUrl: 'https://www.pexels.com/photo/775025',
  pexelsUrl: 'https://www.pexels.com/photo/775025',
};

const faqItems = [
  {
    question: 'O que é uma bicicleta ergométrica?',
    answer: 'Uma bicicleta ergométrica é um equipamento de exercício cardiorrespiratório fixo, projetado para simular o pedalamento sem deslocamento. Ela permite controlar carga, velocidade e monitorar frequência cardíaca, sendo indicada para emagrecimento, condicionamento físico e reabilitação.',
  },
  {
    question: 'Qual é a melhor bicicleta ergométrica para iniciantes?',
    answer: 'Para iniciantes, recomenda-se bicicletas ergométricas verticais com 8 a 12 níveis de resistência, assento ajustável, monitor de frequência cardíaca e peso suportado de ao menos 100 kg. Modelos das marcas Randers, Kikos e Moviment oferecem bom desempenho nessa faixa de entrada.',
  },
  {
    question: 'Quanto tempo pedalar por dia na bicicleta ergométrica?',
    answer: 'O tempo recomendado é de 30 a 60 minutos por sessão, entre 3 e 5 vezes por semana. Iniciantes devem começar com 20 minutos e aumentar gradualmente a duração e intensidade.',
  },
  {
    question: 'Bicicleta ergométrica emagrece?',
    answer: 'Sim. Uma sessão de 45 minutos em intensidade moderada queima entre 300 e 500 kcal, dependendo do peso corporal e da resistência configurada. Combinada com alimentação adequada, contribui diretamente para o déficit calórico necessário ao emagrecimento.',
  },
  {
    question: 'Qual é a diferença entre bicicleta ergométrica vertical e horizontal?',
    answer: 'A bicicleta vertical posiciona o usuário sentado com o tronco ereto, ativando mais os músculos do core e ocupando menos espaço. A bicicleta horizontal distribui o peso nas costas, reduzindo a pressão sobre os joelhos e a coluna, sendo indicada para idosos e pessoas em reabilitação.',
  },
  {
    question: 'Bicicleta ergométrica é boa para joelho?',
    answer: 'Sim, quando usada com a regulagem correta de altura de selim. O movimento cíclico de baixo impacto fortalece os músculos ao redor do joelho sem sobrecarregar as articulações. Modelos horizontais e recumbentes são especialmente recomendados para quem tem artrose ou lesão meniscal.',
  },
];

const perfis = [
  {
    icon: '🏃',
    titulo: 'Quero emagrecer',
    desc: 'Modelos com 12+ níveis de resistência e programas de queima de gordura. Sessões de 40 min em intensidade moderada queimam até 500 kcal.',
    href: '/beneficios-bicicleta-ergometrica/',
    cta: 'Ver modelos para emagrecimento →',
  },
  {
    icon: '🦵',
    titulo: 'Tenho problema de joelho',
    desc: 'Bicicleta horizontal ou recumbente: baixo impacto articular, encosto com suporte lombar, movimento controlado sem risco de lesão.',
    href: '/tipos-de-bicicleta-ergometrica/',
    cta: 'Ver tipos recomendados →',
  },
  {
    icon: '🏠',
    titulo: 'Uso domiciliar leve',
    desc: 'Até 3x por semana, espaço reduzido, orçamento até R$ 1.500. Modelos compactos das marcas Randers e Moviment atendem bem esse perfil.',
    href: '/melhores-bicicletas-ergometricas/',
    cta: 'Ver modelos compactos →',
  },
  {
    icon: '💪',
    titulo: 'Treino intenso / diário',
    desc: 'Uso de 5x/semana ou mais exige estrutura robusta, suporte de 120 kg+, garantia de 2 anos. Athletic, Kikos e Wellness são as marcas certas.',
    href: '/melhores-bicicletas-ergometricas/',
    cta: 'Ver modelos para uso intenso →',
  },
];

const comoEscolher = [
  {
    num: '01',
    titulo: 'Defina seu orçamento',
    desc: 'Até R$ 1.200 (entrada), R$ 1.200–R$ 2.500 (intermediário) ou acima de R$ 2.500 (premium). Cada faixa tem marcas e recursos distintos.',
  },
  {
    num: '02',
    titulo: 'Verifique o peso suportado',
    desc: 'Use no máximo 80% da capacidade declarada. Para 80 kg de peso, escolha modelos com suporte de 100 kg ou mais.',
  },
  {
    num: '03',
    titulo: 'Escolha o tipo certo',
    desc: 'Vertical para espaço pequeno e treino ativo. Horizontal para problemas articulares. Spinning para alta intensidade.',
  },
  {
    num: '04',
    titulo: 'Confira os recursos',
    desc: 'Níveis de resistência (mín. 8), monitor cardíaco, bluetooth (se quiser integrar com apps) e garantia de estrutura.',
  },
];

const marcas = [
  { nome: 'Randers', segmento: 'Entrada', preco: 'R$ 800–R$ 2.200', destaque: 'Melhor custo-benefício', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-randers/' },
  { nome: 'Kikos', segmento: 'Intermediário', preco: 'R$ 1.000–R$ 3.500', destaque: 'Bluetooth e conectividade', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-kikos/' },
  { nome: 'Moviment', segmento: 'Entrada–Intermediário', preco: 'R$ 900–R$ 2.500', destaque: 'Durabilidade estrutural', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-moviment/' },
  { nome: 'Athletic', segmento: 'Intermediário–Premium', preco: 'R$ 1.200–R$ 3.800', destaque: 'Garantia de 2 anos', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-athletic/' },
  { nome: 'Wellness', segmento: 'Premium', preco: 'R$ 2.000–R$ 3.800', destaque: 'Design premium domiciliar', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-wellness/' },
  { nome: 'Technogym', segmento: 'Profissional', preco: 'R$ 8.000+', destaque: 'Padrão Olímpico', href: '/melhores-bicicletas-ergometricas/bicicleta-ergometrica-technogym/' },
];
---

<Layout
  title="Bicicleta Ergométrica: Guia Completo para Compra e Uso no Brasil"
  description="Portal especializado em bicicletas ergométricas: comparativos de modelos, guias de uso, benefícios para a saúde e melhores preços. Tudo o que você precisa saber antes de comprar."
  isHomepage={true}
  faqItems={faqItems}
>

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <span class="badge badge-brand" style="margin-bottom:1rem;display:inline-flex;">
            🚴 Portal de Referência no Brasil
          </span>
          <h1 id="hero-heading">
            A bicicleta ergométrica certa para o seu objetivo
          </h1>
          <p style="font-size:1.125rem;color:rgba(255,255,255,0.9);margin-bottom:2rem;line-height:1.7;">
            Análises técnicas, comparativos de marcas e guias de uso para você escolher com segurança — sem perder dinheiro no modelo errado.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:1rem;">
            <a href="/melhores-bicicletas-ergometricas/" class="btn-cta">Ver Melhores Modelos</a>
            <a href="/como-escolher-bicicleta-ergometrica/" class="btn-primary" style="background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.4);">Como Escolher</a>
          </div>
        </div>
        {heroImage && (
          <div class="hero-image">
            <img
              src={heroImage.url}
              alt={heroImage.alt}
              loading="eager"
              width="560"
              height="400"
            />
            <p class="hero-image-credit">
              Foto: <a href={heroImage.photographerUrl} target="_blank" rel="noopener">{heroImage.photographer}</a> via Pexels
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-bar" aria-label="Números do portal">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <strong>+30</strong>
          <span>modelos analisados</span>
        </div>
        <div class="stat-item">
          <strong>6</strong>
          <span>marcas comparadas</span>
        </div>
        <div class="stat-item">
          <strong>4</strong>
          <span>tipos de bicicleta</span>
        </div>
        <div class="stat-item">
          <strong>R$ 800</strong>
          <span>menor preço avaliado</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PARA QUEM É -->
  <section class="section" aria-labelledby="perfis-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="perfis-heading">Qual é o seu objetivo?</h2>
        <p>Cada perfil tem um tipo e uma faixa de preço ideais. Encontre o seu.</p>
      </div>
      <div class="perfis-grid">
        {perfis.map(p => (
          <article class="perfil-card">
            <div class="perfil-icon">{p.icon}</div>
            <h3>{p.titulo}</h3>
            <p>{p.desc}</p>
            <a href={p.href}>{p.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COMO ESCOLHER -->
  <section class="section-alt" aria-labelledby="escolher-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="escolher-heading">Como escolher a bicicleta certa</h2>
        <p>4 critérios objetivos para não errar na compra.</p>
      </div>
      <div class="steps-grid">
        {comoEscolher.map(s => (
          <div class="step-card">
            <div class="step-num">{s.num}</div>
            <h3>{s.titulo}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/como-escolher-bicicleta-ergometrica/" class="btn-cta">
          Ler guia completo de como escolher
        </a>
      </div>
    </div>
  </section>

  <!-- MARCAS -->
  <section class="section" aria-labelledby="marcas-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="marcas-heading">Principais marcas no Brasil</h2>
        <p>Análise comparativa por segmento de preço e perfil de uso.</p>
      </div>
      <div class="marcas-grid">
        {marcas.map(m => (
          <a href={m.href} class="marca-card">
            <div class="marca-nome">{m.nome}</div>
            <div class="marca-segmento">{m.segmento}</div>
            <div class="marca-preco">{m.preco}</div>
            <div class="marca-destaque">✓ {m.destaque}</div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/melhores-bicicletas-ergometricas/" class="btn-cta">
          Ver comparativo completo de modelos
        </a>
      </div>
    </div>
  </section>

  <!-- EXPLORE POR TEMA -->
  <section class="section-alt" aria-labelledby="temas-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="temas-heading">Explore por tema</h2>
        <p>Conteúdo organizado por etapa da sua decisão de compra.</p>
      </div>
      <div class="cards-grid">
        <article class="card">
          <h3><a href="/tipos-de-bicicleta-ergometrica/">Tipos de Bicicleta Ergométrica</a></h3>
          <p>Vertical, horizontal, spinning e recumbente: entenda as diferenças e escolha o modelo certo para o seu objetivo.</p>
          <a href="/tipos-de-bicicleta-ergometrica/" class="btn-primary" style="font-size:0.875rem;">Explorar guia</a>
        </article>
        <article class="card">
          <h3><a href="/beneficios-bicicleta-ergometrica/">Benefícios da Bicicleta Ergométrica</a></h3>
          <p>Emagrecimento, saúde cardiovascular, reabilitação de joelhos e coluna: os benefícios comprovados da pedalagem regular.</p>
          <a href="/beneficios-bicicleta-ergometrica/" class="btn-primary" style="font-size:0.875rem;">Explorar guia</a>
        </article>
        <article class="card">
          <h3><a href="/como-usar-bicicleta-ergometrica/">Como Usar Bicicleta Ergométrica</a></h3>
          <p>Regulagem, protocolos de treino por objetivo, tempo ideal de uso e controle de frequência cardíaca.</p>
          <a href="/como-usar-bicicleta-ergometrica/" class="btn-primary" style="font-size:0.875rem;">Explorar guia</a>
        </article>
        <article class="card">
          <h3><a href="/preco-bicicleta-ergometrica/">Preço de Bicicleta Ergométrica</a></h3>
          <p>Faixas de preço por categoria, onde comprar com segurança e como identificar o melhor custo-benefício.</p>
          <a href="/preco-bicicleta-ergometrica/" class="btn-primary" style="font-size:0.875rem;">Explorar guia</a>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-final" aria-labelledby="cta-heading">
    <div class="container" style="text-align:center;max-width:600px;">
      <h2 id="cta-heading">Pronto para escolher a sua?</h2>
      <p>Veja o comparativo completo de modelos com especificações, preços e links de compra.</p>
      <a href="/melhores-bicicletas-ergometricas/" class="btn-cta">
        Ver Melhores Bicicletas Ergométricas
      </a>
    </div>
  </section>

  <FAQ items={faqItems} title="Perguntas Frequentes sobre Bicicleta Ergométrica" />

</Layout>

<style>

  /* HERO TWO COLUMNS */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-content { max-width: 560px; }

  .hero-image {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0,0,0,0.25);
  }

  .hero-image img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    display: block;
  }

  .hero-image-credit {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
    padding: 6px 10px;
    background: rgba(0,0,0,0.3);
    margin: 0;
    text-align: right;
  }

  .hero-image-credit a {
    color: rgba(255,255,255,0.6);
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-image { display: none; }
  }

  /* STATS BAR */
  .stats-bar {
    background: var(--token-surface-alt, #f8f8f6);
    border-bottom: 1px solid var(--token-border, #e8e8e4);
    padding: 1.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    text-align: center;
  }

  .stat-item strong {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--token-brand, #2e7d32);
    line-height: 1.1;
  }

  .stat-item span {
    font-size: 0.8rem;
    color: var(--token-text-secondary, #666);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* SECTION HEADER */
  .section-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .section-header h2 {
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--token-text-secondary, #666);
    font-size: 1.0625rem;
    margin: 0;
  }

  /* PERFIS */
  .perfis-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .perfil-card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .perfil-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .perfil-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .perfil-card h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--token-text-primary, #1a1a1a);
  }

  .perfil-card p {
    font-size: 0.9rem;
    color: var(--token-text-secondary, #666);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .perfil-card a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--token-brand, #2e7d32);
    text-decoration: none;
  }

  .perfil-card a:hover {
    text-decoration: underline;
  }

  /* STEPS */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    padding: 1.5rem;
    border-left: 3px solid var(--token-brand, #2e7d32);
  }

  .step-num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--token-brand, #2e7d32);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .step-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--token-text-primary, #1a1a1a);
  }

  .step-card p {
    font-size: 0.9rem;
    color: var(--token-text-secondary, #666);
    line-height: 1.6;
    margin: 0;
  }

  /* MARCAS */
  .marcas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .marca-card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .marca-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    border-color: var(--token-brand, #2e7d32);
  }

  .marca-nome {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--token-text-primary, #1a1a1a);
  }

  .marca-segmento {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--token-text-secondary, #888);
  }

  .marca-preco {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--token-brand, #2e7d32);
    margin-top: 0.25rem;
  }

  .marca-destaque {
    font-size: 0.8rem;
    color: var(--token-text-secondary, #666);
    margin-top: 0.25rem;
  }

  /* CTA FINAL */
  .cta-final {
    background: var(--token-brand, #2e7d32);
    padding: 4rem 1rem;
    color: #fff;
  }

  .cta-final h2 {
    color: #fff;
    margin-bottom: 0.75rem;
    font-size: 1.75rem;
  }

  .cta-final p {
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    font-size: 1.0625rem;
  }

  .cta-final .btn-cta {
    background: #fff;
    color: var(--token-brand, #2e7d32);
  }

  .cta-final .btn-cta:hover {
    background: #f0f0f0;
  }
</style>
