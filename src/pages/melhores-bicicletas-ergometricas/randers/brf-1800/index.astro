---
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import FAQ from '../../../../components/FAQ.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import { fetchBikeImage } from '../../../../lib/pexels.js';

const breadcrumbs = [
  { name: 'Melhores Bicicletas Ergométricas', url: '/melhores-bicicletas-ergometricas/' },
  { name: 'Randers', url: '/melhores-bicicletas-ergometricas/randers/' },
  { name: 'BRF-1800', url: '/melhores-bicicletas-ergometricas/randers/brf-1800/' },
];

const faqItems = [
  {
    question: 'A Randers BRF-1800 tem bluetooth?',
    answer: 'Não. A Randers BRF-1800 não possui conectividade bluetooth. O console exibe velocidade, distância, tempo, calorias e frequência cardíaca (via sensor de mão), mas não se integra com aplicativos de treino. Para conectividade, considere a Kikos FB 180i ou a Athletic Advanced BT.',
  },
  {
    question: 'Qual é o peso máximo suportado pela Randers BRF-1800?',
    answer: 'A Randers BRF-1800 suporta até 120 kg segundo especificação do fabricante. Para uso seguro, recomenda-se não exceder 80% da capacidade declarada — ou seja, usuários de até 96 kg. Esse critério de margem de segurança é padrão na indústria e compensa possíveis imprecisões de laudos entre fabricantes.',
  },
  {
    question: 'Qual é a diferença entre a BRF-1200 e a BRF-1800?',
    answer: 'A BRF-1200 tem 12 níveis de resistência, suporta 100 kg e inclui 8 programas de treino. A BRF-1800 tem 16 níveis, suporta 120 kg e inclui 12 programas. A diferença de preço é de R$ 400 a R$ 600. Para usuários com peso acima de 80 kg ou que treinam mais de 4 vezes por semana, a BRF-1800 oferece margem de segurança e progressão de carga superiores.',
  },
  {
    question: 'A Randers BRF-1800 é silenciosa?',
    answer: 'Sim, em comparação com bicicletas de resistência mecânica. O sistema magnético da BRF-1800 não gera atrito direto, o que reduz o ruído durante o uso. O som predominante é o da correia e das pedaleiras. Para apartamentos, o nível de ruído é adequado em horários normais, mas não para madrugada com vizinhos próximos.',
  },
];

const imagem = await fetchBikeImage("indoor exercise bike magnetic resistance");
---

<Layout
  title="Randers BRF-1800: Análise Completa e Especificações"
  description="Análise da Randers BRF-1800: 16 níveis de resistência magnética, suporte até 120 kg e 12 programas automáticos. Prós, contras e perfil recomendado."
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
  datePublished="2026-03-01"
>
  <Breadcrumb items={breadcrumbs} />

  <section class="section" aria-labelledby="page-heading">
    <div class="container" style="max-width:860px;">

      <h1 id="page-heading">Randers BRF-1800: Análise Completa da Bicicleta Ergométrica</h1>

      <div class="top-pick-box">
        <div class="top-pick-label">Nossa avaliação</div>
        <p>
          A <strong>Randers BRF-1800</strong> é a melhor opção da linha Randers para uso domiciliar regular. Com <strong>16 níveis de resistência magnética</strong>, <strong>120 kg de suporte</strong> e <strong>12 programas automáticos</strong>, entrega o essencial sem bluetooth. Ideal para quem busca um equipamento confiável entre <strong>R$ 1.600 e R$ 2.200</strong> sem dependência de aplicativos.
        </p>
        <div class="top-pick-verdict">
          <span class="verdict-badge verdict-sim">Recomendada para: uso regular sem conectividade</span>
          <span class="verdict-badge verdict-nao">Não indicada para: usuários acima de 96 kg ou que precisam de bluetooth</span>
        </div>
      </div>

      <h2>Especificações técnicas completas</h2>

      <table>
        <tbody>
          <tr><td><strong>Tipo de resistência</strong></td><td>Magnética (sem atrito direto)</td></tr>
          <tr><td><strong>Níveis de resistência</strong></td><td>16</td></tr>
          <tr><td><strong>Peso do volante de inércia</strong></td><td>Não declarado pelo fabricante (estimado: 4–5 kg)</td></tr>
          <tr><td><strong>Peso máximo suportado</strong></td><td>120 kg</td></tr>
          <tr><td><strong>Peso do equipamento</strong></td><td>Aprox. 26 kg</td></tr>
          <tr><td><strong>Dimensões montado</strong></td><td>Aprox. 105 × 56 cm (C × L)</td></tr>
          <tr><td><strong>Programas de treino</strong></td><td>12</td></tr>
          <tr><td><strong>Monitor</strong></td><td>Velocidade, distância, tempo, calorias, FC (sensor de mão)</td></tr>
          <tr><td><strong>Bluetooth / conectividade</strong></td><td>Não</td></tr>
          <tr><td><strong>Ajuste de selim</strong></td><td>Vertical e horizontal</td></tr>
          <tr><td><strong>Ajuste de guidão</strong></td><td>Vertical</td></tr>
          <tr><td><strong>Tipo de transmissão</strong></td><td>Correia</td></tr>
          <tr><td><strong>Garantia estrutura</strong></td><td>12 meses</td></tr>
          <tr><td><strong>Garantia peças</strong></td><td>12 meses</td></tr>
          <tr><td><strong>Preço aproximado</strong></td><td>R$ 1.600 – R$ 2.200</td></tr>
        </tbody>
      </table>

      <h2>Prós e contras</h2>

      <div class="pros-cons">
        <div class="pros">
          <h3>Pontos positivos</h3>
          <ul>
            <li>16 níveis de resistência magnética — progressão de carga ao longo de meses</li>
            <li>Suporte de 120 kg — margem de segurança real para até 96 kg</li>
            <li>12 programas automáticos incluídos — variação sem precisar ajustar manualmente</li>
            <li>Transmissão por correia — mais silenciosa que corrente</li>
            <li>Assistência técnica nas principais capitais brasileiras</li>
          </ul>
        </div>
        <div class="cons">
          <h3>Pontos negativos</h3>
          <ul>
            <li>Sem bluetooth — não integra com Strava, Zwift ou apps de saúde</li>
            <li>Peso do volante não declarado — dificulta comparação objetiva</li>
            <li>Dimensões do guidão não ajustáveis horizontalmente</li>
            <li>Montagem relatada como demorada por usuários</li>
          </ul>
        </div>
      </div>

      <h2>Para quem é indicada a BRF-1800</h2>

      <p>
        A <strong>Randers BRF-1800</strong> é indicada para usuários com peso corporal entre <strong>60 e 96 kg</strong> que treinam de <strong>3 a 5 vezes por semana</strong> em intensidade moderada, sem necessidade de integração com aplicativos. Os 16 níveis de resistência garantem progressão para os primeiros 12 a 18 meses de uso regular.
      </p>

      <p>
        Não é indicada para: usuários acima de 96 kg (prefira modelos com suporte declarado de 130 kg+), atletas que precisam de feedback digital via app, ou quem quer treino de spinning com alta cadência (o volante estimado é mais leve que o ideal para spinning).
      </p>

      <h2>Comparativo com modelos concorrentes</h2>

      <table>
        <thead>
          <tr>
            <th>Modelo</th>
            <th>Níveis</th>
            <th>Suporte</th>
            <th>Bluetooth</th>
            <th>Preço</th>
          </tr>
        </thead>
        <tbody>
          <tr class="highlight-row">
            <td><strong>Randers BRF-1800</strong></td>
            <td>16</td>
            <td>120 kg</td>
            <td>Não</td>
            <td>R$ 1.600–R$ 2.200</td>
          </tr>
          <tr>
            <td><a href="/melhores-bicicletas-ergometricas/kikos/fb-180i/">Kikos FB 180i</a></td>
            <td>16</td>
            <td>110 kg</td>
            <td>Sim (BLE)</td>
            <td>R$ 1.700–R$ 2.200</td>
          </tr>
          <tr>
            <td><a href="/melhores-bicicletas-ergometricas/randers/">Randers BRF-1200</a></td>
            <td>12</td>
            <td>100 kg</td>
            <td>Não</td>
            <td>R$ 1.100–R$ 1.400</td>
          </tr>
          <tr>
            <td><a href="/melhores-bicicletas-ergometricas/dream-fitness/">Dream Fitness Max V</a></td>
            <td>12</td>
            <td>100 kg</td>
            <td>Não</td>
            <td>R$ 900–R$ 1.200</td>
          </tr>
        </tbody>
      </table>

      <p>
        Para o comparativo direto entre as duas marcas mais procuradas, veja <a href="/melhores-bicicletas-ergometricas/randers-vs-kikos/">Randers vs Kikos: qual comprar?</a>
      </p>

      <div style="margin-top: 2rem;">
        <ProductCard product={{
          name: "Bicicleta Ergométrica Randers BRF-1800",
          description: "16 níveis de resistência magnética, 12 programas automáticos e suporte até 120 kg. Melhor opção da linha Randers para uso domiciliar regular.",
          price: "R$ 1.600 – R$ 2.200",
          rating: 4.2,
          reviewCount: 3120,
          badge: "Recomendada",
          affiliateUrl: "https://www.amazon.com.br/s?k=randers+brf+1800&tag=bicicletase0d-20",
          image: imagem?.url,
          imageAlt: "Bicicleta ergométrica Randers BRF-1800 resistência magnética",
          features: [
            "16 níveis de resistência magnética",
            "12 programas automáticos",
            "Suporte até 120 kg",
            "Monitor com sensor de frequência cardíaca",
          ],
        }} />
      </div>

      {imagem && (
        <p style="font-size: 0.75rem; color: #999; margin-top: 0.5rem;">
          Foto: <a href={imagem.photographerUrl} target="_blank" rel="noopener">{imagem.photographer}</a> via <a href={imagem.pexelsUrl} target="_blank" rel="noopener">Pexels</a>
        </p>
      )}

    </div>
  </section>

  <FAQ items={faqItems} title="Perguntas frequentes sobre a Randers BRF-1800" />
</Layout>

<style>
  .top-pick-box {
    background: var(--c-green-50);
    border: 2px solid var(--c-green-300);
    border-radius: var(--token-radius-lg);
    padding: 1.5rem;
    margin: 1.5rem 0 2rem;
  }

  .top-pick-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-green-700);
    margin-bottom: 0.75rem;
  }

  .top-pick-box p {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .top-pick-verdict {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .verdict-badge {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }

  .verdict-sim {
    background: var(--c-green-100);
    color: var(--c-green-700);
  }

  .verdict-nao {
    background: var(--c-gray-100);
    color: var(--c-gray-600);
  }

  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 1.5rem 0;
  }

  .pros, .cons {
    padding: 1.25rem;
    border-radius: var(--token-radius-md);
    border: 1px solid var(--token-border);
  }

  .pros { background: var(--c-green-50); }
  .cons { background: var(--c-gray-50); }

  .pros h3, .cons h3 {
    font-size: 0.9375rem;
    margin: 0 0 0.75rem;
  }

  .pros h3 { color: var(--c-green-700); }
  .cons h3 { color: var(--token-text-secondary); }

  .pros ul, .cons ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .pros li, .cons li {
    font-size: 0.9375rem;
    margin-bottom: 0.375rem;
    line-height: 1.5;
  }

  .highlight-row td {
    background: var(--c-green-50);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
