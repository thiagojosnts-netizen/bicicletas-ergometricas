---
/**
 * curso-vendas.astro — Página de curso/vendas
 *
 * Carrega curso-vendas.yaml do tema ativo e renderiza o template classic.
 */
import { readSingleton } from '../utils/singleton-utils';
import CursoVendasTemplate from '../themes/classic/curso-vendas.astro';

const cursoVendasData = await readSingleton('curso-vendas', 'classic') || {};
---

<CursoVendasTemplate 
    cursoVendasData={cursoVendasData}
    themeId="classic"
/>
