---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const breadcrumbs = [
  { name: 'Blog', url: '/blog/' },
];

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).valueOf() - new Date(a.data.datePublished).valueOf()
);
---

<Layout
  title="Blog: Bicicleta Ergométrica"
  description="Artigos e guias sobre bicicleta ergométrica: montagem, treinos, bicicleta vs esteira e dicas para maximizar seus resultados."
  breadcrumbs={breadcrumbs}
>
  <Breadcrumb items={breadcrumbs} />

  <section class="section" aria-labelledby="blog-heading">
    <div class="container" style="max-width:860px;">
      <h1 id="blog-heading">Blog: Guias e Artigos sobre Bicicleta Ergométrica</h1>
      <p style="margin-bottom:2.5rem;">
        Artigos práticos sobre treino, montagem, comparativos de equipamentos e dicas para quem usa bicicleta ergométrica no Brasil.
      </p>

      <div class="blog-list">
        {posts.map(post => {
          const slug = post.id.replace(/\.md$/, '');
          return (
            <article class="blog-card">
              <div class="blog-card-meta">
                <time datetime={post.data.datePublished}>
                  {new Date(post.data.datePublished).toLocaleDateString('pt-BR', {
                    day: '2-digit', month: 'long', year: 'numeric'
                  })}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.map(tag => (
                      <span class="blog-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2 class="blog-card-title">
                <a href={`/blog/${slug}/`}>{post.data.title}</a>
              </h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <a href={`/blog/${slug}/`} class="blog-read-more">
                Ler artigo →
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
