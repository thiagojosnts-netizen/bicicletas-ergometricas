---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(post => !post.data.draft).map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/\.md$/, '');

const breadcrumbs = [
  { name: 'Blog', url: '/blog/' },
  { name: post.data.title, url: `/blog/${slug}/` },
];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  breadcrumbs={breadcrumbs}
  isArticle={true}
  datePublished={post.data.datePublished}
  dateModified={post.data.dateModified ?? post.data.datePublished}
  faqItems={post.data.faqItems ?? []}
>
  <Breadcrumb items={breadcrumbs} />

  <article class="section" aria-labelledby="post-heading">
    <div class="container prose-container">
      <header style="margin-bottom:2rem;">
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="blog-card-meta" style="margin-bottom:1rem;">
            <div class="blog-tags">
              {post.data.tags.map(tag => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          </div>
        )}
        <h1 id="post-heading">{post.data.title}</h1>
        <div class="article-byline">
          <span class="byline-author">
            Por <a href="/sobre/" class="byline-link">Rafael Souza</a>
          </span>
          <span class="byline-separator">·</span>
          <time datetime={post.data.datePublished}>
            {new Date(post.data.datePublished).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
        <p style="font-size:1.125rem;color:var(--token-text-secondary);margin-top:1rem;">{post.data.description}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--token-border);">
        <a href="/blog/" class="btn-primary" style="font-size:0.875rem;">
          ← Voltar ao blog
        </a>
      </footer>
    </div>
  </article>

  {post.data.faqItems && post.data.faqItems.length > 0 && (
    <FAQ items={post.data.faqItems} title="Perguntas Frequentes" />
  )}
</Layout>

<style>
  .article-byline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.75rem;
  }

  .byline-link {
    color: #2D6A4F;
    text-decoration: none;
  }

  .byline-link:hover {
    text-decoration: underline;
  }

  .byline-separator {
    opacity: 0.5;
  }
</style>
