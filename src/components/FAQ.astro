---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'Perguntas Frequentes' } = Astro.props;
---

<section class="faq-section" aria-labelledby="faq-heading">
  <div class="container">
    <h2 id="faq-heading">{title}</h2>

    <div role="list">
      {items.map((item, index) => (
        <div class="faq-item" role="listitem">
          <h3 class="faq-question" id={`faq-q-${index}`}>
            {item.question}
          </h3>
          <div class="faq-answer" role="region" aria-labelledby={`faq-q-${index}`}>
            <p>{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
