---
interface HowToStep {
  name: string;
  text: string;
  image?: string;
}
interface Props {
  name: string;
  description: string;
  totalTime?: string;
  steps: HowToStep[];
}
const { name, description, totalTime, steps } = Astro.props;
---
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name,
  description,
  ...(totalTime ? { totalTime } : {}),
  step: steps.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: step.name,
    text: step.text,
    ...(step.image ? { image: step.image } : {}),
  })),
})} />
