---
interface FAQ {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQ[];
}
const { faqs = [] } = Astro.props;
---
{faqs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  })} />
)}
