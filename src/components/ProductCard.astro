---
// src/components/ProductCard.astro
// Card de produto com link de afiliado Amazon + imagem Pexels
// Uso: <ProductCard product={...} />

export interface Props {
  product: {
    name: string;
    description: string;
    price: string;
    rating?: number;
    reviewCount?: number;
    affiliateUrl: string;       // Link gerado pelo SiteStripe
    store?: string;             // Ex: "Amazon", "Mercado Livre" (default: "Amazon")
    image?: string;             // URL da imagem (Pexels ou manual)
    imageAlt?: string;
    badge?: string;             // Ex: "Mais Vendido", "Melhor Custo-Benefício"
    features?: string[];
  };
}

const { product } = Astro.props;
const store = product.store ?? "Amazon";
const stars = product.rating ? Math.round(product.rating) : 0;
const btnClass = store === "Mercado Livre" ? "btn-ml" : "btn-cta";
---

<article class="product-card">
  {product.badge && (
    <div class="badge">{product.badge}</div>
  )}

  <div class="card-image">
    {product.image ? (
      <img
        src={product.image}
        alt={product.imageAlt || product.name}
        loading="lazy"
        width="400"
        height="260"
      />
    ) : (
      <div class="image-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4l3 3"/>
        </svg>
        <span>Imagem em breve</span>
      </div>
    )}
  </div>

  <div class="card-body">
    <h3 class="product-name">{product.name}</h3>
    <p class="product-description">{product.description}</p>

    {product.features && product.features.length > 0 && (
      <ul class="features">
        {product.features.map((f) => (
          <li>{f}</li>
        ))}
      </ul>
    )}

    {product.rating && (
      <div class="rating">
        <div class="stars" aria-label={`${product.rating} de 5 estrelas`}>
          {Array.from({ length: 5 }, (_, i) => (
            <span class={i < stars ? "star filled" : "star"}>★</span>
          ))}
        </div>
        {product.reviewCount && (
          <span class="review-count">({product.reviewCount.toLocaleString('pt-BR')} avaliações)</span>
        )}
      </div>
    )}

    <div class="card-footer">
      <div>
        <div class="price">{product.price}</div>
        {store !== "Mercado Livre" && (
          <div class="flex items-center gap-2 text-sm text-gray-500 mt-1">
            <span class="inline-flex items-center gap-1 bg-[#F0FFF4] text-[#2D6A4F] text-xs font-medium px-2 py-0.5 rounded-full border border-[#52B788]">
              ✓ Frete grátis Prime
            </span>
            <span class="text-xs text-gray-400">· Preço verificado hoje</span>
          </div>
        )}
      </div>
      <a
        href={product.affiliateUrl}
        class={btnClass}
        target="_blank"
        rel="noopener nofollow sponsored"
        aria-label={`Ver ${product.name} no ${store}`}
      >
        Ver no {store}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .product-card {
    position: relative;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #ff6b00;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    z-index: 1;
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #f5f5f5;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-image img {
    transform: scale(1.03);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #aaa;
    font-size: 13px;
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 8px;
  }

  .product-name {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    margin: 0;
  }

  .product-description {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
    margin: 0;
  }

  .features {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .features li {
    font-size: 0.8rem;
    color: #555;
    padding-left: 1.1em;
    position: relative;
  }

  .features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2e7d32;
    font-weight: 600;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }

  .stars {
    display: flex;
    gap: 1px;
  }

  .star {
    color: #ddd;
    font-size: 14px;
  }

  .star.filled {
    color: #f4a700;
  }

  .review-count {
    font-size: 12px;
    color: #888;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
  }

  .price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #b12704;
  }

</style>
