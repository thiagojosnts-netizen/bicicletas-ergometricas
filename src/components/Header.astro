---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/tipos-de-bicicleta-ergometrica/', label: 'Tipos' },
  { href: '/como-escolher-bicicleta-ergometrica/', label: 'Como Escolher' },
  { href: '/melhores-bicicletas-ergometricas/', label: 'Melhores' },
  { href: '/preco-bicicleta-ergometrica/', label: 'Preço' },
  { href: '/blog/', label: 'Blog' },
];
---

<header class="site-header" role="banner">
  <div class="header-inner container">

    <a href="/" class="site-logo" aria-label="BicicletasErgometricas.com - Página inicial">
      <span class="logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>
      </span>
      <span class="logo-text">BicicletasErgometricas<span class="logo-dot">.com</span></span>
    </a>

    <nav class="site-nav" id="site-nav" aria-label="Navegação principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={(link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href)) ? 'nav-link active' : 'nav-link'}
          aria-current={(link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href)) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="/melhores-bicicletas-ergometricas/" class="btn-header-cta">
        Ver Melhores Modelos
      </a>
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-controls="site-nav"
        aria-expanded="false"
        aria-label="Abrir menu de navegação"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </div>

  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--token-border);
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    height: var(--token-navbar-h);
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
  }

  /* LOGO */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    color: var(--token-brand);
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 800;
    color: var(--token-text-primary);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .logo-dot {
    color: var(--token-brand);
  }

  /* NAV */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--token-text-secondary);
    text-decoration: none;
    padding: 0.375rem 0.625rem;
    border-radius: var(--token-radius-sm);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--token-brand);
    background: var(--token-brand-light);
  }

  .nav-link.active {
    color: var(--token-brand);
    font-weight: 600;
  }

  /* CTA BUTTON */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .btn-header-cta {
    display: inline-flex;
    align-items: center;
    background: var(--token-brand);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.5rem 1rem;
    border-radius: var(--token-radius-md);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, transform 0.15s;
  }

  .btn-header-cta:hover {
    background: var(--token-brand-hover);
    color: #fff;
    transform: translateY(-1px);
  }

  /* HAMBURGUER */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: var(--token-radius-sm);
  }

  .nav-toggle:hover { background: var(--token-brand-light); }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--token-text-primary);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* MOBILE */
  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .btn-header-cta { display: none; }

    .site-nav {
      display: none;
      position: absolute;
      top: var(--token-navbar-h);
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid var(--token-border);
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem 1.25rem;
      gap: 0;
      z-index: 99;
    }

    .site-nav.is-open { display: flex; }

    .nav-link {
      padding: 0.75rem 0.5rem;
      font-size: 1rem;
      border-bottom: 1px solid var(--token-border);
      border-radius: 0;
    }

    .nav-link:last-child { border-bottom: none; }
  }

  @media (max-width: 1024px) and (min-width: 901px) {
    .nav-link { font-size: 0.8125rem; padding: 0.375rem 0.5rem; }
    .logo-text { font-size: 0.9rem; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-label', expanded ? 'Abrir menu de navegação' : 'Fechar menu de navegação');
  });

  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !nav?.contains(e.target as Node)) {
      toggle?.setAttribute('aria-expanded', 'false');
      nav?.classList.remove('is-open');
      toggle?.setAttribute('aria-label', 'Abrir menu de navegação');
    }
  });
</script>
